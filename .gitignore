# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# ── Virtual envs ────────────────────────────────────────────
.venv/
venv/

# ── Secrets & local state ───────────────────────────────────
.env
tokens.json
*.db
*.log

# ── Tooling caches ──────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
coverage.json
coverage/
htmlcov/
.mypy_cache/
.ruff_cache/

# ── IDEs / editors ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Claude Code ──────────────────────────────────────────────
# Per-machine settings are ignored; the agent roster (project-
# specific specialist prompts) is committed so the team is
# reproducible across machines. Patterns must ignore *contents*
# of .claude/ (not the directory itself), otherwise gitignore's
# negation rules can't re-include `agents/`.
.claude/*
!.claude/agents/

# ── OS cruft ────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Installer backups (install.sh / install.ps1 write these) ─
*.backup.*
